# =========================
# Security & Credentials
# =========================
# CRITICAL: Never commit your API keys!
.env

# =========================
# Machine Learning Models
# =========================
# Ignore YOLO downloaded weights (they are large and can be auto-downloaded)
*.pt
*.weights
# Ignore YOLO training/inference output folders
runs/

# =========================
# Video & Media Files
# =========================
# Ignore test videos and temporary files generated by Streamlit/OpenCV
*.mp4
*.avi
*.mov
*.mkv
temp_video*
sample_crowd*

# =========================
# Python Environment & Cache
# =========================
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Virtual Environments
venv/
.venv/
env/
.env_folder/

# =========================
# Streamlit & OS Files
# =========================
# Ignore Streamlit secrets if you ever create them
.streamlit/secrets.toml

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db